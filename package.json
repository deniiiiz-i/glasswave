  "types": "./dist/packages/index.d.ts",
  "exports": {
    ".": {
      "types": "./packages/index.ts",
      "import": "./packages/index.ts",
      "default": "./packages/index.ts"
    },
    "./styles": "./packages/index.css"
  },
  "publishConfig": {
    "main": "./dist/packages/index.js",
    "module": "./dist/packages/index.js",
    "types": "./dist/packages/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/packages/index.d.ts",
        "import": "./dist/packages/index.js",
        "default": "./dist/packages/index.js"
      },
      "./styles": "./dist/index.css"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && pnpm exec postcss packages/index.css -o dist/index.css && node -e \"const fs=require('fs');const f='dist/packages/index.js';fs.writeFileSync(f,'import \\\"../index.css\\\";\\n'+fs.readFileSync(f,'utf8'));\"",
    "dev": "tsc --watch & pnpm exec postcss packages/index.css -o dist/index.css --watch",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format"
  },
  "packageManager": "pnpm@10.20.0",
